<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ══════════════════════════════════════════════
             CATÉGORIE DU MODULE
        ══════════════════════════════════════════════ -->
        <record id="module_category_pharmacie" model="ir.module.category">
            <field name="name">Pharmacie</field>
            <field name="sequence">100</field>
        </record>

        <!-- ══════════════════════════════════════════════
             GROUPES UTILISATEURS
        ══════════════════════════════════════════════ -->

        <!-- Vendeur : ventes au comptoir, lecture stock/médicaments -->
        <record id="group_pharmacie_vendeur" model="res.groups">
            <field name="name">Vendeur</field>
            <field name="category_id" ref="module_category_pharmacie"/>
        </record>

        <!-- Pharmacien : droits étendus sauf réappro complet
             NOTE : pas d'implied_ids vers Vendeur. Chaque groupe a ses propres
             droits ACL explicites dans ir.model.access.csv. Faire hériter
             Pharmacien de Vendeur ajouterait automatiquement l'utilisateur au
             groupe Vendeur, ce qui le ferait tomber sous le coup de la record
             rule "un vendeur ne voit que ses ventes" (rule_vendeur_own_ventes) —
             alors que Pharmacien/Gestionnaire doivent voir TOUTES les ventes. -->
        <record id="group_pharmacie_pharmacien" model="res.groups">
            <field name="name">Pharmacien</field>
            <field name="category_id" ref="module_category_pharmacie"/>
        </record>

        <!-- Gestionnaire : accès total (même remarque : pas d'implied_ids) -->
        <record id="group_pharmacie_gestionnaire" model="res.groups">
            <field name="name">Gestionnaire</field>
            <field name="category_id" ref="module_category_pharmacie"/>
        </record>

        <!-- ══════════════════════════════════════════════
             RECORD RULE
             Un vendeur ne voit que ses propres ventes
        ══════════════════════════════════════════════ -->
        <record id="rule_vendeur_own_ventes" model="ir.rule">
            <field name="name">Vendeur — ses ventes seulement</field>
            <field name="model_id" ref="model_pharmacie_vente"/>
            <field name="domain_force">[('vendeur_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_pharmacie_vendeur'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
