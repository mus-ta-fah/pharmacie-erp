<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ══════════════════════════════════════════════
             SÉQUENCES AUTOMATIQUES
        ══════════════════════════════════════════════ -->
        <record id="seq_pharmacie_lot" model="ir.sequence">
            <field name="name">Numéro de lot</field>
            <field name="code">pharmacie.lot</field>
            <field name="prefix">LOT/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_pharmacie_vente" model="ir.sequence">
            <field name="name">Référence vente</field>
            <field name="code">pharmacie.vente</field>
            <field name="prefix">VTE/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_pharmacie_reappro" model="ir.sequence">
            <field name="name">Bon de commande pharmacie</field>
            <field name="code">pharmacie.reappro</field>
            <field name="prefix">BC/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
        </record>

        <!-- ══════════════════════════════════════════════
             TÂCHE PLANIFIÉE — Mise à jour quotidienne du statut des lots
             (valide → expiré dès que date_peremption est dépassée)
        ══════════════════════════════════════════════ -->
        <record id="cron_pharmacie_update_statuts_lots" model="ir.cron">
            <field name="name">Pharmacie : mise à jour statut des lots (péremption)</field>
            <field name="model_id" ref="model_pharmacie_lot"/>
            <field name="state">code</field>
            <field name="code">model._cron_update_statuts()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <!-- ══════════════════════════════════════════════
             CATÉGORIES DE MÉDICAMENTS
        ══════════════════════════════════════════════ -->
        <record id="cat_antibiotiques" model="pharmacie.categorie">
            <field name="name">Antibiotiques</field>
            <field name="code">ANTI</field>
            <field name="description">Médicaments antibactériens</field>
        </record>
        <record id="cat_penicillines" model="pharmacie.categorie">
            <field name="name">Pénicillines</field>
            <field name="code">PENI</field>
            <field name="parent_id" ref="cat_antibiotiques"/>
        </record>
        <record id="cat_analgesiques" model="pharmacie.categorie">
            <field name="name">Analgésiques</field>
            <field name="code">ANAL</field>
        </record>
        <record id="cat_antipaludiques" model="pharmacie.categorie">
            <field name="name">Antipaludiques</field>
            <field name="code">APAL</field>
        </record>
        <record id="cat_antihypertenseurs" model="pharmacie.categorie">
            <field name="name">Antihypertenseurs</field>
            <field name="code">AHYP</field>
        </record>
        <record id="cat_vitamines" model="pharmacie.categorie">
            <field name="name">Vitamines et compléments</field>
            <field name="code">VITA</field>
        </record>

        <!-- ══════════════════════════════════════════════
             FOURNISSEURS PHARMACEUTIQUES (démo)
        ══════════════════════════════════════════════ -->
        <record id="fournisseur_laborex" model="res.partner">
            <field name="name">Laborex Sénégal</field>
            <field name="is_company" eval="True"/>
            <field name="is_fournisseur_pharma" eval="True"/>
            <field name="delai_livraison_moyen">3</field>
            <field name="numero_agrement">DPM/2020/0042</field>
            <field name="phone">+221 33 889 00 00</field>
            <field name="city">Dakar</field>
            <field name="country_id" ref="base.sn"/>
        </record>

        <record id="fournisseur_copharmed" model="res.partner">
            <field name="name">Copharmed</field>
            <field name="is_company" eval="True"/>
            <field name="is_fournisseur_pharma" eval="True"/>
            <field name="delai_livraison_moyen">5</field>
            <field name="numero_agrement">DPM/2018/0017</field>
            <field name="phone">+221 33 832 00 00</field>
            <field name="city">Dakar</field>
            <field name="country_id" ref="base.sn"/>
        </record>

        <record id="fournisseur_sodipharm" model="res.partner">
            <field name="name">Sodipharm</field>
            <field name="is_company" eval="True"/>
            <field name="is_fournisseur_pharma" eval="True"/>
            <field name="delai_livraison_moyen">7</field>
            <field name="numero_agrement">DPM/2019/0033</field>
            <field name="city">Thiès</field>
            <field name="country_id" ref="base.sn"/>
        </record>

        <!-- ══════════════════════════════════════════════
             MÉDICAMENTS DE DÉMONSTRATION (10 minimum)
        ══════════════════════════════════════════════ -->
        <record id="med_amoxicilline" model="pharmacie.medicament">
            <field name="nom_commercial">Amoxil®</field>
            <field name="dci">Amoxicilline</field>
            <field name="forme">comprime</field>
            <field name="dosage">500 mg</field>
            <field name="conditionnement">Boîte de 24 comprimés</field>
            <field name="categorie_id" ref="cat_penicillines"/>
            <field name="fournisseur_id" ref="fournisseur_laborex"/>
            <field name="prix_achat">850</field>
            <field name="prix_vente">1200</field>
            <field name="taux_tva">0</field>
            <field name="sur_ordonnance" eval="True"/>
            <field name="alerte_rupture">20</field>
        </record>

        <record id="med_paracetamol" model="pharmacie.medicament">
