            <field name="date_peremption" eval="(datetime.today() + relativedelta(days=10)).strftime('%Y-%m-%d')"/>
            <field name="quantite_initiale">30</field>
            <field name="quantite_restante">6</field>
            <field name="prix_achat_lot">1200</field>
        </record>
        <record id="lot_ibuprofen_1" model="pharmacie.lot">
            <field name="medicament_id" ref="med_ibuprofen"/>
            <field name="date_fabrication" eval="(datetime.today() - relativedelta(months=2)).strftime('%Y-%m-%d')"/>
