            <field name="medicament_id" ref="med_vitaminec"/>
            <field name="date_fabrication" eval="(datetime.today() - relativedelta(months=5)).strftime('%Y-%m-%d')"/>
            <field name="date_peremption" eval="(datetime.today() + relativedelta(days=250)).strftime('%Y-%m-%d')"/>
            <field name="quantite_initiale">80</field>
            <field name="quantite_restante">55</field>
            <field name="prix_achat_lot">400</field>
        </record>
        <record id="lot_metronidazole_1" model="pharmacie.lot">
