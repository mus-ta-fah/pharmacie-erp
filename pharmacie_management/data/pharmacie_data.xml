        </record>

        <record id="med_zinc" model="pharmacie.medicament">
            <field name="nom_commercial">Rubozinc®</field>
            <field name="dci">Gluconate de zinc</field>
            <field name="forme">gelule</field>
            <field name="dosage">15 mg</field>
            <field name="conditionnement">Boîte de 60 gélules</field>
            <field name="categorie_id" ref="cat_vitamines"/>
