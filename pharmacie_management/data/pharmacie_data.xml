            <field name="prix_vente">2200</field>
            <field name="taux_tva">18</field>
            <field name="sur_ordonnance" eval="False"/>
            <field name="alerte_rupture">10</field>
        </record>

        <!-- ══════════════════════════════════════════════
             LOTS DE STOCK (démo — 7 lots, dates variées pour
             démontrer les alertes de péremption)
        ══════════════════════════════════════════════ -->
        <record id="lot_amoxicilline_1" model="pharmacie.lot">
            <field name="medicament_id" ref="med_amoxicilline"/>
            <field name="date_fabrication" eval="(datetime.today() - relativedelta(months=6)).strftime('%Y-%m-%d')"/>
            <field name="date_peremption" eval="(datetime.today() + relativedelta(days=20)).strftime('%Y-%m-%d')"/>
            <field name="quantite_initiale">50</field>
            <field name="quantite_restante">45</field>
            <field name="prix_achat_lot">850</field>
        </record>
        <record id="lot_paracetamol_1" model="pharmacie.lot">
            <field name="medicament_id" ref="med_paracetamol"/>
            <field name="date_fabrication" eval="(datetime.today() - relativedelta(months=3)).strftime('%Y-%m-%d')"/>
            <field name="date_peremption" eval="(datetime.today() + relativedelta(days=730)).strftime('%Y-%m-%d')"/>
            <field name="quantite_initiale">200</field>
            <field name="quantite_restante">180</field>
            <field name="prix_achat_lot">250</field>
        </record>
        <record id="lot_artemether_1" model="pharmacie.lot">
