        </record>

        <!-- ══════════════════════════════════════════════
             VENTES (démo — 5 ventes confirmées)
        ══════════════════════════════════════════════ -->
        <record id="vente_demo_1" model="pharmacie.vente">
            <field name="vendeur_id" ref="base.user_admin"/>
            <field name="mode_paiement">especes</field>
            <field name="statut">confirmee</field>
            <field name="date_vente" eval="(datetime.now() - relativedelta(days=5)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="reference">VTE/DEMO/0001</field>
            <field name="ligne_ids" eval="[(0, 0, {
                'medicament_id': ref('med_paracetamol'),
                'quantite': 2,
                'prix_unitaire': 400,
            })]"/>
        </record>
        <record id="vente_demo_2" model="pharmacie.vente">
