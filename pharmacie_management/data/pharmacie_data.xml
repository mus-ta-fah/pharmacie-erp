            <field name="dci">Paracétamol</field>
            <field name="forme">comprime</field>
            <field name="dosage">1000 mg</field>
            <field name="conditionnement">Boîte de 16 comprimés</field>
            <field name="categorie_id" ref="cat_analgesiques"/>
            <field name="fournisseur_id" ref="fournisseur_copharmed"/>
            <field name="prix_achat">250</field>
            <field name="prix_vente">400</field>
            <field name="taux_tva">0</field>
            <field name="sur_ordonnance" eval="False"/>
            <field name="alerte_rupture">30</field>
