            <field name="taux_tva">0</field>
            <field name="sur_ordonnance" eval="True"/>
            <field name="alerte_rupture">15</field>
        </record>

        <record id="med_omeprazole" model="pharmacie.medicament">
            <field name="nom_commercial">Mopral®</field>
            <field name="dci">Oméprazole</field>
            <field name="forme">gelule</field>
            <field name="dosage">20 mg</field>
            <field name="conditionnement">Boîte de 28 gélules</field>
            <field name="categorie_id" ref="cat_analgesiques"/>
            <field name="fournisseur_id" ref="fournisseur_sodipharm"/>
            <field name="prix_achat">900</field>
            <field name="prix_vente">1400</field>
            <field name="taux_tva">0</field>
            <field name="sur_ordonnance" eval="False"/>
            <field name="alerte_rupture">10</field>
        </record>

        <record id="med_salbutamol" model="pharmacie.medicament">
            <field name="nom_commercial">Ventoline®</field>
            <field name="dci">Salbutamol</field>
            <field name="forme">autre</field>
            <field name="dosage">100 µg/dose</field>
            <field name="conditionnement">Flacon pressurisé 200 doses</field>
            <field name="categorie_id" ref="cat_analgesiques"/>
            <field name="fournisseur_id" ref="fournisseur_laborex"/>
            <field name="prix_achat">2500</field>
            <field name="prix_vente">3800</field>
            <field name="taux_tva">0</field>
            <field name="sur_ordonnance" eval="True"/>
