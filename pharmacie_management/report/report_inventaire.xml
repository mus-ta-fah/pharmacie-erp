<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="report_inventaire_template">
    <t t-call="web.html_container">
      <t t-call="web.external_layout">
        <div class="page">

          <h2 class="text-center">INVENTAIRE DES STOCKS</h2>
          <p class="text-center text-muted">
            Édité le <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y à %H:%M')"/>
          </p>

          <!-- Légende couleurs -->
          <div class="d-flex gap-3 mb-3">
            <span class="badge text-bg-danger">Rouge : péremption &lt; 30 jours</span>
            <span class="badge text-bg-warning">Orange : péremption &lt; 90 jours</span>
            <span class="badge text-bg-success">Vert : stock normal</span>
          </div>

          <table class="table table-bordered table-sm">
            <thead class="table-dark">
              <tr>
                <th>N° Lot</th>
                <th>Médicament</th>
                <th>DCI</th>
                <th>Catégorie</th>
                <th class="text-center">Qté init.</th>
                <th class="text-center">Qté rest.</th>
                <th>Date fab.</th>
                <th>Date pér.</th>
                <th class="text-center">Jours rest.</th>
                <th>Statut</th>
              </tr>
            </thead>
            <tbody>
              <t t-foreach="docs" t-as="lot">
                <tr t-attf-class="#{'table-danger' if lot.jours_avant_peremption &lt; 30 and lot.statut == 'valide' else ('table-warning' if lot.jours_avant_peremption &lt; 90 and lot.statut == 'valide' else '')}">
                  <td><t t-esc="lot.numero_lot"/></td>
                  <td><t t-esc="lot.medicament_id.nom_commercial"/></td>
                  <td><t t-esc="lot.medicament_id.dci"/></td>
                  <td><t t-esc="lot.medicament_id.categorie_id.name"/></td>
                  <td class="text-center"><t t-esc="lot.quantite_initiale"/></td>
                  <td class="text-center"><strong><t t-esc="lot.quantite_restante"/></strong></td>
                  <td><t t-esc="lot.date_fabrication"/></td>
                  <td><t t-esc="lot.date_peremption"/></td>
                  <td class="text-center"><t t-esc="lot.jours_avant_peremption"/></td>
                  <td><t t-esc="lot.statut"/></td>
                </tr>
              </t>
            </tbody>
          </table>

          <p class="mt-3">
            <strong>Total lots affichés : <t t-esc="len(docs)"/></strong>
          </p>
          <div class="mt-4 text-right">
            <p>Signature du pharmacien responsable : ___________________________</p>
          </div>

        </div>
      </t>
    </t>
  </template>
</odoo>
